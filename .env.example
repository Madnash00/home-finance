HOST=127.0.0.1
PORT=8766
DATA_DIR=./data
# Percorso facoltativo a una cartella sincronizzata da Google Drive Desktop
# macOS: ~/Library/CloudStorage/GoogleDrive-account@example.com/My Drive/CasaFinance
# Windows: G:\Il mio Drive\CasaFinance
DRIVE_BACKUP_DIR=
DRIVE_AUTO_BACKUP=true
# Obbligatorio per installazioni pubbliche. Se vuoto, l'autenticazione è disattivata.
APP_USERNAME=admin
APP_PASSWORD=
# Solo per una prima migrazione facoltativa da un vecchio modello Excel
INITIAL_MODEL_FILE=
INITIAL_MOVEMENTS_FILE=
